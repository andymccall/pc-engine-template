# Build output (everything under build/ and release/ is generated by the
# Makefile).
build/
release/

# Toolchain intermediates (pceas emits .lst listings, .sym symbol files,
# .map memory maps alongside the .pce).
*.o
*.lst
*.sym
*.map

# Binary artefacts produced by the build (keep raw assets under assets/).
*.pce
*.sgx
*.iso
*.ovl
*.bin
!assets/**/*.bin

# Per-user editor / agent settings.
.claude/
__pycache__/
*.pyc
